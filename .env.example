# Server Configuration
PORT=3000
MONGO_URI=mongodb://localhost:27017/pixelscript
MONGODB_URI=mongodb://localhost:27017/pixelscript
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# File Upload Configuration
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# Session Configuration
SESSION_SECRET=your_session_secret_here
SESSION_EXPIRES_IN=86400000  # 24 hours in milliseconds

# CORS Configuration
CORS_ORIGIN=http://localhost:3000
SOCKET_CORS_ORIGIN=http://localhost:3000

# API rate limiting and logging
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=300
LOG_LEVEL=info

# Backup and retention
BACKUP_OUTPUT_DIR=./backups
BACKUP_RETENTION_DAYS=30

# E2E role flow checks (optional)
E2E_BASE_URL=http://localhost:3000
E2E_ARTIST_NAME=E2E Artist
E2E_ARTIST_USERNAME=e2e_artist
E2E_ARTIST_EMAIL=e2e.artist@example.com
E2E_ARTIST_PASSWORD=E2Epass123!
E2E_WRITER_NAME=E2E Writer
E2E_WRITER_USERNAME=e2e_writer
E2E_WRITER_EMAIL=e2e.writer@example.com
E2E_WRITER_PASSWORD=E2Epass123!
E2E_READER_NAME=E2E Reader
E2E_READER_USERNAME=e2e_reader
E2E_READER_EMAIL=e2e.reader@example.com
E2E_READER_PASSWORD=E2Epass123!

# Socket.IO Horizontal Scaling (optional)
REDIS_URL=redis://localhost:6379
SOCKET_PRESENCE_TTL_SECONDS=172800

# Cloudinary (required for uploaded media)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=pixelscript

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# AI Configuration
OPENAI_API_KEY=your_openai_compatible_api_key_here
OPENAI_MODEL=qwen/qwen3-32b
OPENAI_BASE_URL=https://api.groq.com/openai
# Optional (used by some providers, safe to leave empty)
AI_HTTP_REFERER=http://localhost:3000
AI_APP_TITLE=PixelScript

# Contact email notifications (optional; emails are skipped if unset)
EMAIL_SERVICE=
EMAIL_USER=
EMAIL_PASS=

