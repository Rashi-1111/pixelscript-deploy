{
  "name": "pixelscript",
  "version": "1.0.0",
  "description": "A collaborative platform for artists and writers",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "backup:run": "node scripts/backup-atlas-cloudinary.js",
    "backup:prune": "node scripts/prune-backups.js",
    "backup:prune:dry": "node scripts/prune-backups.js --dry-run",
    "migrate:purchase-indexes": "node scripts/migrate-purchase-indexes.js",
    "e2e:roles": "node scripts/e2e-role-flow-checks.js",
    "e2e:roles:artist": "node scripts/e2e-role-flow-checks.js --flow artist-upload",
    "e2e:roles:writer": "node scripts/e2e-role-flow-checks.js --flow writer-publish",
    "e2e:roles:reader": "node scripts/e2e-role-flow-checks.js --flow reader-view",
    "e2e:roles:purchase": "node scripts/e2e-role-flow-checks.js --flow purchase-unlock"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "connect-mongo": "^5.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.5.1",
    "express-session": "^1.18.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.13.2",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^8.0.6",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "razorpay": "^2.9.6",
    "redis": "^4.7.0",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=14.0.0"
  },
